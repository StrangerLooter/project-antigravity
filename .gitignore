# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/lib/node_modules
/lib/

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (DO NOT commit .env files with secrets)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev server logs
devserver.*.log
*.log

# large binary / native modules
**/*.node